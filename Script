  return(df)
}


# Normality test and Homogeneity of variance test
check_function <- function(index,group_var,data){
  # construct the formula from the column name strings
  formula_str <- paste(index, "~", group_var)
  formula_obj <- as.formula(formula_str)
  # Fit the ANOVA model using the constructed formula
  fit <- aov(formula_obj, data = data)
  res <- residuals(fit)
  # Get the vectors needed for plotting (safe extraction using [[ operator]])
  group_data <- data[[group_var]]
  par(mfrow=c(1,2))
  # Normality Check
  qqnorm(res, main = "Normal Q-Q Plot of Residuals"); 
  qqline(res)
  cat("\nNormality test (Shapiro-Wilk):\n")
  print(shapiro.test(res))
  # Homogeneity of Variance Check (Residuals vs. Fitted/Group)
  cat("\nResiduals vs. Group Plot (Homogeneity):\n")
  plot(group_data, res, 
       xlab = group_var, 
       ylab = "Residuals",
       main = "Residuals vs. Group")
  abline(h=0, col="red")
  cat("\nHomogeneity of variance test (Levene's Test):\n")
  # Use the constructed formula with leveneTest
  print(leveneTest(formula_obj, data = data))
  par(mfrow=c(1,1))
}

kw_function <- function(formula, data){
  kw_test <- kruskal.test(formula,data = data)
  print(kw_test)
  posthoc <- dunn_test(data = data,formula,p.adjust.method = "fdr")
  posthoc$compar <- paste(posthoc$group1,"-",posthoc$group2,sep="")
  print(posthoc)
  return(posthoc)
}

aov_function <- function(formula, data){
  aov <- aov(formula,data = data)
  print(summary(aov))
  posthoc <- as.data.frame(TukeyHSD(aov)[[1]])
  posthoc$compar <- rownames(posthoc)
  colnames(posthoc)[colnames(posthoc) == "p adj"] <- "p.adj"
  posthoc<-separate(data = posthoc,col = compar,into = c("group1", "group2"),sep = "-")
  posthoc$compar <- paste(posthoc$group2,"-",posthoc$group1,sep = "")
  print(posthoc)
  return(posthoc)
}





